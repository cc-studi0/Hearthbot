<Window x:Class="BotMain.DeckSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择卡组" Width="360" Height="430"
        WindowStartupLocation="CenterOwner" Background="White"
        FontFamily="Segoe UI" FontSize="12" Foreground="#1B1F23"
        ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="SmartBotTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="勾选参与随机的卡组；全部取消时回退为(auto)。"
                   TextWrapping="Wrap" Margin="0,0,0,8"/>

        <Border Grid.Row="1" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="4" Padding="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding DeckItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Name}"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Margin="0,2"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="全选" Width="60" Height="28" Margin="0,0,8,0" Click="OnSelectAll"/>
            <Button Content="清空" Width="60" Height="28" Margin="0,0,8,0" Click="OnClear"/>
            <Button Content="确定" Width="70" Height="28" IsDefault="True" Click="OnOk"/>
            <Button Content="取消" Width="70" Height="28" Margin="8,0,0,0" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
