<Window x:Class="BotMain.AccountControllerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="多账号中控" Width="780" Height="520"
        WindowStartupLocation="CenterOwner" Background="#F0F0F0"
        FontFamily="Segoe UI" FontSize="12">
    <DockPanel Margin="8">
        <!-- 顶部：战网实例 -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="战网实例:" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold"/>
            <ComboBox x:Name="BnetInstanceCombo" Width="280" Height="24" FontSize="11"
                      DisplayMemberPath="DisplayText"/>
            <Button Content="刷新" Width="45" Height="24" Margin="4,0,0,0" FontSize="11"
                    Click="OnRefreshBnetInstances"/>
            <TextBlock x:Name="BnetCountText" VerticalAlignment="Center" Margin="8,0,0,0"
                       FontSize="11" Foreground="#666"/>
        </StackPanel>

        <!-- 底部：状态栏 + 按钮 -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,6,0,0">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="▶ 开始队列" Width="85" Height="28" FontSize="11"
                        Click="OnStartQueue" x:Name="StartBtn"/>
                <Button Content="■ 停止队列" Width="85" Height="28" Margin="4,0,0,0" FontSize="11"
                        Click="OnStopQueue" x:Name="StopBtn"/>
            </StackPanel>
            <TextBlock x:Name="StatusTextBlock" VerticalAlignment="Center" FontSize="11" Foreground="#333"
                       Text="未启动"/>
        </DockPanel>

        <!-- 中部：账号列表 + 操作按钮 -->
        <DockPanel>
            <!-- 右侧操作按钮 -->
            <StackPanel DockPanel.Dock="Right" Width="80" Margin="6,0,0,0">
                <Button Content="添加" Height="28" FontSize="11" Margin="0,0,0,4" Click="OnAddAccount"/>
                <Button Content="编辑" Height="28" FontSize="11" Margin="0,0,0,4" Click="OnEditAccount"/>
                <Button Content="删除" Height="28" FontSize="11" Margin="0,0,0,4" Click="OnRemoveAccount"/>
                <Button Content="↑ 上移" Height="28" FontSize="11" Margin="0,0,0,4" Click="OnMoveUp"/>
                <Button Content="↓ 下移" Height="28" FontSize="11" Margin="0,0,0,4" Click="OnMoveDown"/>
                <Separator Margin="0,4"/>
                <Button Content="重置状态" Height="28" FontSize="11" Margin="0,4,0,4" Click="OnResetAll"/>
            </StackPanel>

            <!-- 账号列表 DataGrid -->
            <DataGrid x:Name="AccountGrid" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      SelectionMode="Single" GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column" FontSize="11"
                      Background="White" BorderThickness="1" BorderBrush="#CCC"
                      RowHeaderWidth="0" ColumnHeaderHeight="26">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="昵称" Binding="{Binding DisplayName}" Width="70"/>
                    <DataGridTextColumn Header="战网窗口" Binding="{Binding BattleNetLabel}" Width="110"/>
                    <DataGridTextColumn Header="模式" Binding="{Binding ModeName}" Width="50"/>
                    <DataGridTextColumn Header="卡组" Binding="{Binding DeckName}" Width="90"/>
                    <DataGridTextColumn Header="策略" Binding="{Binding ProfileName}" Width="90"/>
                    <DataGridTextColumn Header="目标段位" Binding="{Binding TargetRankText}" Width="70"/>
                    <DataGridTextColumn Header="状态" Binding="{Binding StatusText}" Width="55"/>
                    <DataGridTextColumn Header="战绩" Binding="{Binding StatsText}" Width="65"/>
                    <DataGridTextColumn Header="当前段位" Binding="{Binding CurrentRankText}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </DockPanel>
</Window>
