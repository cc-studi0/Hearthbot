                    && c.Template.Id == SketchArtist
                    && c.CurrentCost <= manaNow);
            bool preferSketchFirstWindow = sketchPlayableNow
                && board != null
                && board.Hand != null
                && rayStartupHandCount > AbductionRayNonTempPreferredMaxHand
                && !tempLikeWindow
                && !continuationWindow
                && !HasPlayedCard(board, AbductionRay);
