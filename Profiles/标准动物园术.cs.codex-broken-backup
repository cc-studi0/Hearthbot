                }
                AddLog("濮嬬榫燂細鍦轰笂绉嶆棌<2锛屼絾鍙悓鍥炲悎灏忕簿鐏佃仈鍔紝鏀惧鍚庣疆闄愬埗");
            }
            else
            {
                if (enemyHasMinion)
                {
                    // 鏁屾柟鏈夊満鏃朵弗鏍兼墽琛屸€滆嚦灏?绉嶆棌鈥濋棬妲涳紝涓嶅啀鍋?绉嶆棌鍏滃簳鏀惧銆?
