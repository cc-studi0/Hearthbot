                            if (isRay)
                                AddLog("鎸熸寔灏勭嚎涓存椂閾捐窡韪細鍙充晶鏂板鎸熸寔灏勭嚎锛岀户鎵夸复鏃舵爣璁?);
                            else
                                AddLog("鎸熸寔灏勭嚎涓存椂閾捐窡韪細鍙充晶鏂板闈炴専鎸佸皠绾匡紝涓嶇户鎵夸复鏃舵爣璁?);
                        }

                        if (markAsTemporary)
