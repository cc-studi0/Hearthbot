            if (rayPlayableNow)
                AddLog("濮嬬榫燂細鎸熸寔灏勭嚎鍙敤浣嗘湭閿佸畾锛屼笉寮哄埗鍚庣疆");

            // 鐢ㄦ埛瑙勫垯锛氬悗鏈熷绁栭緹涓嶅簲鎶㈠厛銆?
            // 褰撳洖鍚堝瓨鍦ㄥ叾浠栧彲鎵撳姩浣滐紙灏ゅ叾鏄澶栨伓榄旓級鏃讹紝濮嬬榫熷悗缃浣嶈妭濂忓姩浣溿€?
