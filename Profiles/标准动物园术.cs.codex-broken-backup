                    SetSingleCardCombo(board, p, TortollanStoryteller, allowCoinBridge: true, forceOverride: true,
                        logWhenSet: enemyHasMinion
                            ? "濮嬬榫燂細鏁屾柟鏈夊満涓旂被鍨?=2鏃禖omboSet浼樺厛钀藉湴"
