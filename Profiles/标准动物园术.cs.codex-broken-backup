        private bool ShouldConcedeWhenNoSolution(
            Board board,
            int friendHp,
            int enemyHp,
            int friendAttackNow,
            int enemyAttackTotal,
            int enemyAttackNow,
            int manaNow)
        {
            if (board == null)
