        {
            public int ManaNow;
            public bool TempLikeWindow;
            public bool RayStartedThisTurn;
            public int RayStartupHandCount;
            public bool AllowNonTempResourceWindow;
            public bool MidLateMultiRayWindow;
            public bool NonTempStartupManaWindow;
