                return false;

            int enemyHp = GetHeroHealth(board.HeroEnemy);
            int friendAttack = GetBoardAttack(board.MinionFriend);
            bool enemyHasTaunt = board.MinionEnemy != null && board.MinionEnemy.Any(m => m != null && m.IsTaunt);
